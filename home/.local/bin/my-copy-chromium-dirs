#! /usr/bin/env python3

import argparse
import json
import os
import shutil
import sqlite3
import sys
from pathlib import Path


ROOT_FILES = [
    "Local State",
    "First Run",
]

LOCK_NAMES = {
    "SingletonLock",
    "SingletonSocket",
    "SingletonCookie",
}


PROFILE_PATHS = [
    # Profile configuration.
    "Preferences",
    "Secure Preferences",

    # Sessions / tabs.
    "Sessions",
    "Current Session",
    "Current Tabs",
    "Last Session",
    "Last Tabs",

    # Main auth/session state.
    #
    # Modern Chromium usually keeps cookies under Network/Cookies.
    # Older layouts may keep Cookies at the profile root.
    "Network",
    "Cookies",
    "Cookies-journal",
    "Cookies-wal",
    "Cookies-shm",

    # Passwords / autofill / account-ish browser DBs.
    "Login Data",
    "Login Data-journal",
    "Login Data-wal",
    "Login Data-shm",
    "Web Data",
    "Web Data-journal",
    "Web Data-wal",
    "Web Data-shm",

    # Site state used by logged-in web apps.
    "Session Storage",
    "Local Storage",
    "IndexedDB",
    "databases",
    "File System",
    "Service Worker",
    "SharedStorage",
    "blob_storage",
    "DIPS",
    "DIPS-journal",
    "DIPS-wal",
    "DIPS-shm",

    # Extra network/session state.
    "TransportSecurity",
    "Trust Tokens",
    "Trust Tokens-journal",
    "Trust Tokens-wal",
    "Trust Tokens-shm",
    "Private State Tokens",
    "Private State Tokens-journal",
    "Private State Tokens-wal",
    "Private State Tokens-shm",
    "Reporting and NEL",
    "Reporting and NEL-journal",
    "Reporting and NEL-wal",
    "Reporting and NEL-shm",

    # Extensions.
    "Extensions",
    "Extension State",
    "Extension Rules",
    "Extension Scripts",
    "Extension Cookies",
    "Local Extension Settings",
    "Sync Extension Settings",
    "Managed Extension Settings",

    # Useful browsing/profile state.
    "History",
    "History-journal",
    "History-wal",
    "History-shm",
    "Favicons",
    "Favicons-journal",
    "Favicons-wal",
    "Favicons-shm",
    "Visited Links",
    "Top Sites",
    "Top Sites-journal",
    "Shortcuts",
    "Shortcuts-journal",
]


def eprint(*args):
    print(*args, file=sys.stderr)


def lexists(path: Path) -> bool:
    return os.path.lexists(path)


def ensure_not_running(user_data_dir: Path, label: str) -> None:
    found = sorted(name for name in LOCK_NAMES if lexists(user_data_dir / name))
    if found:
        raise RuntimeError(
            f"{label} Chromium user-data-dir appears to be in use:\n"
            f"  {user_data_dir}\n\n"
            f"Found: {', '.join(found)}\n"
            f"Close Chromium using that directory before copying."
        )


def remove_dst(dst: Path) -> None:
    if not lexists(dst):
        return

    if dst.is_dir() and not dst.is_symlink():
        shutil.rmtree(dst)
    else:
        dst.unlink()


def copy_one(src_root: Path, dst_root: Path, relative: Path) -> None:
    src = src_root / relative
    dst = dst_root / relative

    if not lexists(src):
        return

    dst.parent.mkdir(parents=True, exist_ok=True)

    # Important: replace instead of merging. SQLite DBs plus stale -wal/-shm
    # files from a previous target profile can make Chromium see weird state.
    remove_dst(dst)

    if src.is_dir() and not src.is_symlink():
        shutil.copytree(
            src,
            dst,
            symlinks=True,
            copy_function=shutil.copy2,
        )
    else:
        shutil.copy2(src, dst, follow_symlinks=False)


def find_profiles(src: Path) -> list[Path]:
    return sorted(
        child
        for child in src.iterdir()
        if child.is_dir() and (child / "Preferences").is_file()
    )


def force_restore_on_startup(profile_dst: Path) -> None:
    prefs_path = profile_dst / "Preferences"
    if not prefs_path.is_file():
        return

    try:
        data = json.loads(prefs_path.read_text())
    except Exception as exc:
        eprint(f"warning: could not parse {prefs_path}: {exc}")
        return

    data.setdefault("session", {})["restore_on_startup"] = 1

    tmp = prefs_path.with_name(prefs_path.name + ".tmp")
    tmp.write_text(json.dumps(data, separators=(",", ":"), ensure_ascii=False))
    tmp.replace(prefs_path)


def cookie_db_report(profile: Path) -> None:
    candidates = [
        profile / "Network" / "Cookies",
        profile / "Cookies",
    ]

    for db in candidates:
        if not db.is_file():
            continue

        try:
            conn = sqlite3.connect(f"file:{db}?mode=ro", uri=True)
            try:
                row = conn.execute(
                    """
                    SELECT
                      COUNT(*),
                      COALESCE(SUM(CASE WHEN length(encrypted_value) > 0 THEN 1 ELSE 0 END), 0),
                      COALESCE(SUM(CASE WHEN length(value) > 0 THEN 1 ELSE 0 END), 0)
                    FROM cookies
                    """
                ).fetchone()
            finally:
                conn.close()
        except Exception as exc:
            eprint(f"cookie report: {db}: could not read: {exc}")
            continue

        total, encrypted, plaintext = row
        eprint(
            f"cookie report: {db}: "
            f"{total} cookies, {encrypted} encrypted, {plaintext} plaintext"
        )


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("source")
    parser.add_argument("target")
    parser.add_argument(
        "--no-force-restore",
        action="store_true",
        help="Do not modify Preferences to enable session restore.",
    )
    args = parser.parse_args()

    src = Path(args.source).expanduser().resolve()
    dst = Path(args.target).expanduser().resolve()

    if not src.is_dir():
        eprint(f"error: source is not a directory: {src}")
        return 1

    if not (src / "Local State").is_file():
        eprint(f"error: not a Chromium user-data-dir: {src}")
        eprint(f"missing: {src / 'Local State'}")
        return 1

    ensure_not_running(src, "source")
    if dst.exists():
        ensure_not_running(dst, "target")

    dst.mkdir(parents=True, exist_ok=True)

    for name in ROOT_FILES:
        copy_one(src, dst, Path(name))

    profiles = find_profiles(src)
    if not profiles:
        eprint(f"error: no Chromium profiles found in {src}")
        return 1

    for profile_src in profiles:
        profile_rel = profile_src.relative_to(src)
        profile_dst = dst / profile_rel

        eprint(f"copying profile: {profile_rel}")

        for item in PROFILE_PATHS:
            copy_one(src, dst, profile_rel / item)

        if not args.no_force_restore:
            force_restore_on_startup(profile_dst)

        cookie_db_report(profile_dst)

    eprint()
    eprint("Done.")
    eprint()
    eprint("Try:")
    eprint(f'  chromium --user-data-dir="{dst}"')
    eprint()
    eprint("If tabs restore but every site asks you to sign in again,")
    eprint("the cookies were probably copied but cannot be decrypted by this OS user/keyring.")

    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except RuntimeError as exc:
        eprint(f"error: {exc}")
        raise SystemExit(1)
