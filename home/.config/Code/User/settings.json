{
    "workbench.colorTheme": "Visual Studio 2019 Dark",
    "editor.cursorStyle": "block",
    "git.enableSmartCommit": true,
    "git.confirmSync": false,
    "chat.tools.terminal.autoApprove": {
        "/.*/": true,
        "iex": false,
        "curl": true
    },
    "files.autoSave": "onFocusChange",
    "github.copilot.enable": {
        "*": true,
        "markdown": true,
        "scminput": false,
        "plaintext": true
    },
    "chat.agent.maxRequests": 900,
    "github.copilot.nextEditSuggestions.enabled": true,
    "window.zoomLevel": -1,
    "remote.autoForwardPortsSource": "hybrid",
    "editor.renderWhitespace": "trailing",
    "git.replaceTagsWhenPull": true,
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "githubPullRequests.codingAgent.promptForConfirmation": false,
    "explorer.confirmDelete": false,
    "chat.tools.urls.autoApprove": {
        "https://www.hiv.lanl.gov/content/sequence/HIV/REVIEWS/HXB2.html": true,
        "https://www.hiv.lanl.gov/content/sequence/HIV/REVIEWS": true,
        "https://www.hiv.lanl.gov/content/sequence/HIV": true,
        "https://www.hiv.lanl.gov/content/sequence": true,
        "https://www.hiv.lanl.gov/content": true,
        "https://www.hiv.lanl.gov": true,
        "https://*.hiv.lanl.gov": true,
        "https://*.lanl.gov": true,
        "https://github.com/mickael-kerjean/filestash/blob/master/server/common/helper.go": true,
        "https://github.com/mickael-kerjean/filestash/blob/master/server/common": true,
        "https://github.com/mickael-kerjean/filestash/blob/master/server": true,
        "https://github.com/mickael-kerjean/filestash/blob/master": true,
        "https://github.com/mickael-kerjean/filestash/blob": true,
        "https://github.com/mickael-kerjean/filestash": true,
        "https://github.com/mickael-kerjean": true,
        "https://github.com": true,
        "https://github.com/mickael-kerjean/filestash/search": true,
        "https://raw.githubusercontent.com/mickael-kerjean/filestash/master/server/common/app.go": true,
        "https://raw.githubusercontent.com/mickael-kerjean/filestash/master/server/common": true,
        "https://raw.githubusercontent.com/mickael-kerjean/filestash/master/server": true,
        "https://raw.githubusercontent.com/mickael-kerjean/filestash/master": true,
        "https://raw.githubusercontent.com/mickael-kerjean/filestash": true,
        "https://raw.githubusercontent.com/mickael-kerjean": true,
        "https://raw.githubusercontent.com": true,
        "https://*.githubusercontent.com": true,
        "https://raw.githubusercontent.com/mickael-kerjean/filestash/master/server/common/default.go": true,
        "https://etetoolkit.github.io/ete/tutorial/tutorial_trees.html": true,
        "https://etetoolkit.github.io/ete/tutorial": true,
        "https://etetoolkit.github.io/ete": true,
        "https://etetoolkit.github.io": true,
        "https://*.github.io": true,
        "https://github.com/etetoolkit/ete/blob/master/changelog.md": true,
        "https://github.com/etetoolkit/ete/blob/master": true,
        "https://github.com/etetoolkit/ete/blob": true,
        "https://github.com/etetoolkit/ete": true,
        "https://github.com/etetoolkit": true,
        "https://pypi.org": true
    },
    "editor.minimap.enabled": false,
    "git.openRepositoryInParentFolders": "never",
    "githubPullRequests.pullBranch": "never"
}